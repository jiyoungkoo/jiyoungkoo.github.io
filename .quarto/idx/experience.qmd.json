{"title":"Experience","markdown":{"yaml":{"title":"Experience","format":{"html":{"css":"styles.css","toc":false,"page-layout":"full"}}},"headingText":"Early Experience","containsRefs":false,"markdown":"\n\n::: {.exp-section}\n\n<div class=\"exp-card\">\n\n<div class=\"exp-header\">\n  <div class=\"exp-company\">Qualcomm</div>\n  <div class=\"exp-meta\">Business Analytics Consultant (Capstone) · Apr 2026 – Present</div>\n</div>\n\n<div class=\"exp-body\">\n\n<ul>\n<li>Building predictive models to forecast NRE spend by integrating program, labor, and financial data</li>\n<li>Improving forecast accuracy and cost visibility for strategic decision-making</li>\n</ul>\n\n</div>\n\n</div>\n\n<div class=\"exp-card\">\n\n<div class=\"exp-header\">\n  <div class=\"exp-company\">POSCO International</div>\n  <div class=\"exp-meta\">Full-time · Mar 2014 – Jun 2025</div>\n</div>\n\n<div class=\"exp-body\">\n\n<strong>Business Operation Manager (FP&A, Strategy)</strong>\n<span class=\"exp-submeta\">Jul 2024 – Jun 2025</span>\n\n<ul>\n<li>Led long-term strategic planning through KPI development and multi-scenario financial modeling</li>\n<li>Supported portfolio and investment decisions across production, pricing, and FX scenarios</li>\n</ul>\n\n<strong>Cost Controller, Offshore Gas Field Development Project (EPCIC)</strong>\n<span class=\"exp-submeta\">Jan 2021 – Jun 2024</span>\n\n<ul>\n<li>Managed financial operations for a multi-hundred-million-dollar EPCIC project</li>\n<li>Led CAPEX forecasting, variance analysis, and executive reporting</li>\n</ul>\n\n<strong>Treasury Analyst (Trade Finance)</strong>\n<span class=\"exp-submeta\">Mar 2020 – Dec 2020</span>\n\n<ul>\n<li>Reduced financing costs through negotiation of L/C and Open Account transactions</li>\n<li>Improved liquidity via receivables factoring and A/R cycle optimization</li>\n</ul>\n\n<strong>Enterprise Risk Analyst (Credit, A/R, Inventory, FX, Insurance, Compliance) </strong>\n<span class=\"exp-submeta\">Mar 2014 – Feb 2020</span>\n\n<ul>\n<li>Analyzed global counterparties to mitigate credit risk</li>\n<li>Built SAP-based risk models and early warning systems</li>\n</ul>\n\n</div>\n\n</div>\n\n\n<div class=\"exp-card\">\n\n<div class=\"exp-body\">\n\n<strong>Trade Finance Intern · Scotiabank</strong>\n<span class=\"exp-submeta\">Dec 2013 – Jan 2014 · Seoul, South Korea</span>\n\n<ul>\n<li>Reviewed L/C documentation and supported trade finance operations</li>\n<li>Assisted with regulatory reporting to the Bank of Korea</li>\n</ul>\n\n<strong>Credit Risk Analyst Intern · POSCO International</strong>\n<span class=\"exp-submeta\">Jun 2013 – Oct 2013 · Seoul, South Korea</span>\n\n<ul>\n<li>Conducted credit risk analysis and prepared approval reports for senior management</li>\n</ul>\n\n</div>\n\n</div>\n\n</div>\n","srcMarkdownNoYaml":"\n\n::: {.exp-section}\n\n<div class=\"exp-card\">\n\n<div class=\"exp-header\">\n  <div class=\"exp-company\">Qualcomm</div>\n  <div class=\"exp-meta\">Business Analytics Consultant (Capstone) · Apr 2026 – Present</div>\n</div>\n\n<div class=\"exp-body\">\n\n<ul>\n<li>Building predictive models to forecast NRE spend by integrating program, labor, and financial data</li>\n<li>Improving forecast accuracy and cost visibility for strategic decision-making</li>\n</ul>\n\n</div>\n\n</div>\n\n<div class=\"exp-card\">\n\n<div class=\"exp-header\">\n  <div class=\"exp-company\">POSCO International</div>\n  <div class=\"exp-meta\">Full-time · Mar 2014 – Jun 2025</div>\n</div>\n\n<div class=\"exp-body\">\n\n<strong>Business Operation Manager (FP&A, Strategy)</strong>\n<span class=\"exp-submeta\">Jul 2024 – Jun 2025</span>\n\n<ul>\n<li>Led long-term strategic planning through KPI development and multi-scenario financial modeling</li>\n<li>Supported portfolio and investment decisions across production, pricing, and FX scenarios</li>\n</ul>\n\n<strong>Cost Controller, Offshore Gas Field Development Project (EPCIC)</strong>\n<span class=\"exp-submeta\">Jan 2021 – Jun 2024</span>\n\n<ul>\n<li>Managed financial operations for a multi-hundred-million-dollar EPCIC project</li>\n<li>Led CAPEX forecasting, variance analysis, and executive reporting</li>\n</ul>\n\n<strong>Treasury Analyst (Trade Finance)</strong>\n<span class=\"exp-submeta\">Mar 2020 – Dec 2020</span>\n\n<ul>\n<li>Reduced financing costs through negotiation of L/C and Open Account transactions</li>\n<li>Improved liquidity via receivables factoring and A/R cycle optimization</li>\n</ul>\n\n<strong>Enterprise Risk Analyst (Credit, A/R, Inventory, FX, Insurance, Compliance) </strong>\n<span class=\"exp-submeta\">Mar 2014 – Feb 2020</span>\n\n<ul>\n<li>Analyzed global counterparties to mitigate credit risk</li>\n<li>Built SAP-based risk models and early warning systems</li>\n</ul>\n\n</div>\n\n</div>\n\n## Early Experience\n\n<div class=\"exp-card\">\n\n<div class=\"exp-body\">\n\n<strong>Trade Finance Intern · Scotiabank</strong>\n<span class=\"exp-submeta\">Dec 2013 – Jan 2014 · Seoul, South Korea</span>\n\n<ul>\n<li>Reviewed L/C documentation and supported trade finance operations</li>\n<li>Assisted with regulatory reporting to the Bank of Korea</li>\n</ul>\n\n<strong>Credit Risk Analyst Intern · POSCO International</strong>\n<span class=\"exp-submeta\">Jun 2013 – Oct 2013 · Seoul, South Korea</span>\n\n<ul>\n<li>Conducted credit risk analysis and prepared approval reports for senior management</li>\n</ul>\n\n</div>\n\n</div>\n\n</div>\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"ipynb-shell-interactivity":null,"plotly-connected":true,"engine":"markdown"},"render":{"keep-te